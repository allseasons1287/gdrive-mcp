# Service account JSON contents (the entire JSON, not a path)
GOOGLE_SA_JSON={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}

# Bearer token clients must present in Authorization header
MCP_AUTH_TOKEN=replace_with_random_64_char_hex

# Folder ID where audit log lives
AUDIT_FOLDER_ID=1Uz46o5NAk3jtkEwA4UNbKWVHeWTVKadm

# Audit log buffer config
AUDIT_BUFFER_SIZE=10
AUDIT_FLUSH_INTERVAL_SECONDS=30

# HTTP server bind
HOST=0.0.0.0
PORT=8000
